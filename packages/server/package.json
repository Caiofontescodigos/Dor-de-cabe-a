{
  "name": "@domino-online/server",
  "version": "0.1.0",
  "description": "Backend do jogo de Dominó Online",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "start:prod": "npm run build && node dist/index.js",
    "pm2:start": "npm run build && pm2 start dist/index.js --name domino-server --update-env && pm2 start dist/worker.js --name domino-worker --update-env",
    "pm2:stop": "pm2 stop domino-server domino-worker",
    "pm2:restart": "npm run build && pm2 restart domino-server domino-worker --update-env",
    "pm2:logs": "pm2 logs",
    "type-check": "tsc --noEmit"
  },
  "keywords": ["domino", "game", "socket.io", "realtime"],
  "author": "Domino Online Team",
  "license": "MIT",
  "dependencies": {
    "express": "4.18.2",
    "socket.io": "4.7.2",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "@aws-sdk/client-sqs": "latest",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.10.6",
    "@types/cors": "2.8.17",
    "@types/uuid": "9.0.7",
    "typescript": "5.3.3",
    "tsx": "4.7.0"
  }
}
